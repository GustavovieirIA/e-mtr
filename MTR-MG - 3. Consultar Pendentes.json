    {
      "parameters": {
        "method": "POST",
        "url": "={{ 'https://mtr.meioambiente.mg.gov.br/api/retornaListaCodigoBarasManifesto/' + $('Consultar MTRs Webhook').first().json.body.dataInicio + '/' + $('Consultar MTRs Webhook').first().json.body.dataFim }}",
        "sendHeaders": true,
        "specifyHeaders": "json",
        "jsonHeaders": "={\n  \"Content-Type\": \"application/json\",\n  \"Authorization\": \"{{ 'Bearer ' + $json.token }}\",\n  \"chave_feam\": \"{{ $json.chave }}\"\n}",
        "sendBody": false,
        "options": {}
      },
      "id": "d4e5f6a7-b8c9-0123-defa-234567890123",
      "name": "Busca Barcodes",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [720, 0]
    },
    {
      "parameters": {
        "jsCode": "const resp = $input.first().json;\n\nif (resp.retornoCodigo !== undefined && resp.retornoCodigo !== 0) {\n  return [{ json: {\n    _done: true, sucesso: false, total: 0, totalPendentes: 0, manifests: [],\n    mensagem: `❌ Erro ${resp.retornoCodigo}: ${resp.retorno}`\n  } }];\n}\n\n// Barcode: [10 nº manifesto][8 cód gerador][8 cód transportador][8 cód destinador]\n// Nosso codUnidadeDestinador = 255271 → padded 8 dígitos = '00255271'\nconst MEU_COD = '00255271';\nconst codigos = resp.codigos || [];\nconst auth = $('Extrai Token').first().json;\n\nconst filtrados = codigos.filter(b => b.length >= 34 && b.substring(26, 34) === MEU_COD);\n\nif (filtrados.length === 0) {\n  return [{ json: {\n    _done: true, sucesso: true, total: 0, totalPendentes: 0, manifests: [],\n    mensagem: `✅ 0 MTR(s) pendente(s) como destinador no período (${codigos.length} manifesto(s) no total)`\n  } }];\n}\n\nreturn filtrados.map(barcode => ({ json: { barcode, token: auth.token, chave: auth.chave } }));"
      },
      "id": "e5f6a7b8-c9d0-1234-efab-345678901234",
