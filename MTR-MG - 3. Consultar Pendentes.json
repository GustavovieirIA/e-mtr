    {
      "parameters": {
        "jsCode": "const auth = $input.first().json;\nif (auth.retornoCodigo !== 0) throw new Error('Falha autenticação: ' + auth.retorno);\nreturn [{ json: { token: auth.token, chave: auth.chave } }];"
