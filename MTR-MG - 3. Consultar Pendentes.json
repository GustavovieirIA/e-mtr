      "id": "b8c9d0e1-f2a3-4567-bcde-678901234567",
      "name": "Busca Manifesto",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1440, 120]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst todos = items.map(i => i.json).filter(m => m.manifestoCodigo !== undefined);\n\nconst SITUACOES = {\n  1: 'Emitido (aguarda baixa)',\n  3: 'Recebido',\n  4: 'Cancelado',\n  9: 'Armazenamento Temp.'\n};\n\n// Filtra apenas os pendentes de baixa (situação 1 = Salvo/Emitido)\nconst pendentes = todos.filter(m => m.situacaoManifestoCodigo === 1);\n\nconst result = pendentes.map(m => ({\n  manifestoCodigo: m.manifestoCodigo,\n  manifDataExpedicao: m.manifDataExpedicao || m.manifData,\n  cnpGerador: m.cnpGerador,\n  cnpTransportador: m.cnpTransportador,\n  situacaoManifestoCodigo: m.situacaoManifestoCodigo,\n  situacao: SITUACOES[m.situacaoManifestoCodigo] || `Situação ${m.situacaoManifestoCodigo}`\n}));\n\nreturn [{ json: {\n  sucesso: true,\n  total: todos.length,\n  totalPendentes: result.length,\n  manifests: result,\n  mensagem: `✅ ${result.length} MTR(s) pendente(s) de baixa (de ${todos.length} como destinador no período)`\n} }];"
      },
