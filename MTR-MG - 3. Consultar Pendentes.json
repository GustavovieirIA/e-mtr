        "method": "POST",
        "url": "={{ 'https://mtr.meioambiente.mg.gov.br/api/retornaManifesto/' + $json.barcode }}",
        "sendHeaders": true,
        "specifyHeaders": "json",
        "jsonHeaders": "={\n  \"Content-Type\": \"application/json\",\n  \"Authorization\": \"{{ 'Bearer ' + $json.token }}\",\n  \"chave_feam\": \"{{ $json.chave }}\"\n}",
        "sendBody": false,
